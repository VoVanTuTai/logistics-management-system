generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ManifestStatus {
  CREATED
  SEALED
  RECEIVED
}

enum OutboxStatus {
  PENDING
  PUBLISHED
  FAILED
}

model Manifest {
  id                 String        @id @default(cuid())
  manifestCode       String        @unique
  status             ManifestStatus @default(CREATED)
  originHubCode      String?
  destinationHubCode String?
  note               String?
  sealedAt           DateTime?
  receivedAt         DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  items              ManifestItem[]
  sealRecord         SealRecord?
  receiveRecord      ReceiveRecord?

  @@map("manifests")
}

model ManifestItem {
  id          String   @id @default(cuid())
  manifestId  String
  shipmentCode String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  manifest    Manifest @relation(fields: [manifestId], references: [id])

  @@index([manifestId])
  @@index([shipmentCode])
  @@map("manifest_items")
}

model SealRecord {
  id         String   @id @default(cuid())
  manifestId String   @unique
  sealedBy   String?
  note       String?
  sealedAt   DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  manifest   Manifest @relation(fields: [manifestId], references: [id])

  @@map("seal_records")
}

model ReceiveRecord {
  id         String   @id @default(cuid())
  manifestId String   @unique
  receivedBy String?
  note       String?
  receivedAt DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  manifest   Manifest @relation(fields: [manifestId], references: [id])

  @@map("receive_records")
}

model OutboxEvent {
  id            String       @id @default(cuid())
  eventId       String       @unique
  eventType     String
  routingKey    String
  aggregateType String
  aggregateId   String?
  payload       Json
  status        OutboxStatus @default(PENDING)
  retryCount    Int          @default(0)
  occurredAt    DateTime
  publishedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status, occurredAt])
  @@map("outbox_events")
}
