{
  "info": {
    "name": "JMS Auth Service",
    "_postman_id": "2b43dd70-cb2c-43e6-b8ec-9ff4769a0ad5",
    "description": "Auth-service smoke flow: health -> login -> introspect -> refresh -> logout",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Health status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.environment.set('accessToken', body.tokens.accessToken);",
              "pm.environment.set('refreshToken', body.tokens.refreshToken);",
              "pm.environment.unset('oldAccessToken');"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - Introspect (Active)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"accessToken\": \"{{accessToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/introspect",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "introspect"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Introspect status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Token active = true', function () {",
              "  pm.expect(body.active).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - Refresh",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.environment.set('oldAccessToken', pm.environment.get('accessToken'));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Refresh status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.environment.set('accessToken', body.tokens.accessToken);",
              "pm.environment.set('refreshToken', body.tokens.refreshToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/refresh",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "refresh"
          ]
        }
      },
      "response": []
    },
    {
      "name": "05 - Introspect Old Token (Inactive)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"accessToken\": \"{{oldAccessToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/introspect",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "introspect"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Introspect old token status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Old token active = false', function () {",
              "  pm.expect(body.active).to.eql(false);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "06 - Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"accessToken\": \"{{accessToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "logout"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Logout status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('revoked = true', function () {",
              "  pm.expect(body.revoked).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "07 - Introspect After Logout (Inactive)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"accessToken\": \"{{accessToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/introspect",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "introspect"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Introspect after logout status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Token active = false', function () {",
              "  pm.expect(body.active).to.eql(false);",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "event": [],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3010"
    },
    {
      "key": "username",
      "value": "demo"
    },
    {
      "key": "password",
      "value": "123456"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "oldAccessToken",
      "value": ""
    }
  ]
}
