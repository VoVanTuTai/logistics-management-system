generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OutboxStatus {
  PENDING
  PUBLISHED
  FAILED
}

model Hub {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  zoneCode  String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hubs")
}

model Zone {
  id         String   @id @default(cuid())
  code       String   @unique
  name       String
  parentCode String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("zones")
}

model NdrReason {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ndr_reasons")
}

model Config {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  scope       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("configs")
}

model OutboxEvent {
  id           String       @id @default(cuid())
  eventId      String       @unique
  eventType    String
  routingKey   String
  aggregateType String
  aggregateId  String?
  payload      Json
  status       OutboxStatus @default(PENDING)
  retryCount   Int          @default(0)
  occurredAt   DateTime
  publishedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status, occurredAt])
  @@map("outbox_events")
}
