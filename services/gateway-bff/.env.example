PORT=3000
GATEWAY_AUTH_ENABLED=false

AUTH_SERVICE_URL=http://auth-service:3010
DELIVERY_SERVICE_URL=http://delivery-service:3007
DISPATCH_SERVICE_URL=http://dispatch-service:3004
MANIFEST_SERVICE_URL=http://manifest-service:3005
MASTERDATA_SERVICE_URL=http://masterdata-service:3001
PICKUP_SERVICE_URL=http://pickup-service:3003
REPORTING_SERVICE_URL=http://reporting-service:3009
SCAN_SERVICE_URL=http://scan-service:3006
SHIPMENT_SERVICE_URL=http://shipment-service:3002
TRACKING_SERVICE_URL=http://tracking-service:3008
PAYMENT_SERVICE_URL=http://payment-service:3011

# Marketplace integration adapter
NEXUS_INTEGRATION_AUTH_ENABLED=true
NEXUS_INTEGRATION_PARTNER_CODE=DT_COMMERCE
NEXUS_INTEGRATION_API_KEY=<set-secure-api-key>
NEXUS_INTEGRATION_API_SECRET=<set-secure-api-secret>
NEXUS_INTEGRATION_WEBHOOK_SECRET=<set-secure-webhook-secret>
NEXUS_INTEGRATION_REQUIRE_SHOP_MAPPING=true
NEXUS_INTEGRATION_SHOP_MAPPINGS_JSON=[]
NEXUS_INTEGRATION_TIMESTAMP_SKEW_MS=300000
NEXUS_INTEGRATION_NONCE_TTL_MS=86400000
OPS_PUBLIC_URL=https://ops.nexus-ex.site
PUBLIC_TRACKING_PUBLIC_URL=https://tracking.nexus-ex.site

# S3 Object Storage Configuration
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET_NAME=nexus-pod-images
S3_FORCE_PATH_STYLE=true
