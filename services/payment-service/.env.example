PORT=3011
DATABASE_URL=postgresql://postgres:postgres@localhost:15432/payment_db
RABBITMQ_URL=amqp://guest:guest@localhost:5672
DOMAIN_EVENTS_EXCHANGE=domain.events
RABBITMQ_MANAGEMENT_PORT=15672
OUTBOX_RELAY_INTERVAL_MS=1000
OUTBOX_RELAY_BATCH_SIZE=50
SHIPMENT_SERVICE_URL=http://localhost:3002

# === Company bank account for COD QR transfer ===
# Update these with real company bank info
COMPANY_BANK_NAME=Vietcombank
COMPANY_BANK_ACCOUNT_NUMBER=1234567890
COMPANY_BANK_ACCOUNT_NAME=CONG TY TNHH NEXUS EXPRESS
COMPANY_BANK_BIN=970436

# === SePay COD settlement webhook ===
# Configure either HMAC (recommended) or API key in SePay dashboard.
# Public webhook URL can point directly to payment-service or through gateway:
#   /cod/webhooks/sepay/settlements
#   /public/payment/cod/webhooks/sepay/settlements
SEPAY_WEBHOOK_SECRET=
SEPAY_WEBHOOK_API_KEY=
SEPAY_WEBHOOK_TOLERANCE_SECONDS=300
SEPAY_BANK_ACCOUNT_NUMBER=1234567890
SEPAY_AMOUNT_TOLERANCE_VND=0
