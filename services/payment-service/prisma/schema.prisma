generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentMethod {
  COD
  BANK_TRANSFER
  PREPAID
}

enum CodCollectionStatus {
  PENDING
  COLLECTED
  REMITTED
  FAILED
}

enum CodSettlementStatus {
  WAITING_PAYMENT
  PAID
  CANCELLED
}

enum OutboxStatus {
  PENDING
  PUBLISHED
  FAILED
}

model CodRecord {
  id              String              @id @default(cuid())
  shipmentCode    String              @unique
  merchantId      String?
  codAmount       Float
  currency        String              @default("VND")
  paymentMethod   PaymentMethod       @default(COD)
  status          CodCollectionStatus @default(PENDING)
  courierId       String?
  collectedAt     DateTime?
  collectedAmount Float?
  remittedAt      DateTime?
  remittedBy      String?
  note            String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status, courierId])
  @@index([shipmentCode])
  @@map("cod_records")
}

model CodSettlementBatch {
  id             String              @id @default(cuid())
  settlementCode String              @unique
  reportDate     DateTime
  hubCode        String
  courierId      String
  totalAmount    Float
  status         CodSettlementStatus @default(WAITING_PAYMENT)
  qrUrl          String?
  transferMemo   String
  createdBy      String?
  confirmedBy    String?
  confirmedAt    DateTime?
  confirmedNote  String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  items          CodSettlementItem[]

  @@index([reportDate, hubCode, courierId])
  @@map("cod_settlement_batches")
}

model CodSettlementPaymentEvent {
  id                  String   @id @default(cuid())
  provider            String
  providerEventId     String
  referenceType       String?
  settlementBatchId   String?
  settlementCode      String?
  codRecordId         String?
  shipmentCode        String?
  amount              Float
  accountNumber       String?
  transferType        String?
  referenceCode       String?
  transactionDate     DateTime?
  processingStatus    String
  ignoredReason       String?
  rawPayload          Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([provider, providerEventId])
  @@index([referenceType])
  @@index([settlementBatchId])
  @@index([settlementCode])
  @@index([codRecordId])
  @@index([shipmentCode])
  @@map("cod_settlement_payment_events")
}

model CodSettlementItem {
  id           String @id @default(cuid())
  batchId      String
  codRecordId  String
  shipmentCode String
  amount       Float

  batch        CodSettlementBatch @relation(fields: [batchId], references: [id])

  @@unique([codRecordId])
  @@map("cod_settlement_items")
}

model IdempotencyRecord {
  id              String   @id @default(cuid())
  idempotencyKey  String   @unique
  scope           String
  responsePayload Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("idempotency_records")
}

model OutboxEvent {
  id            String       @id @default(cuid())
  eventId       String       @unique
  eventType     String
  routingKey    String
  aggregateType String
  aggregateId   String
  payload       Json
  status        OutboxStatus @default(PENDING)
  retryCount    Int          @default(0)
  occurredAt    DateTime
  publishedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status, occurredAt])
  @@map("outbox_events")
}
