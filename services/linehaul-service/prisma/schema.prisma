generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum DriverStatus {
  ACTIVE
  INACTIVE
}

enum TripStatus {
  PLANNED
  LOADING
  SEALED
  DEPARTED
  ARRIVED
  RECEIVING
  COMPLETED
  INCIDENT_REPORTED
  CANCELLED
}

enum TripManifestStatus {
  LOADED
  UNLOADED
  EXCEPTION
}

enum SealDirection {
  OUTBOUND
  INBOUND
}

model Vehicle {
  id           String        @id @default(cuid())
  vehicleCode  String        @unique
  licensePlate String        @unique
  vehicleType  String?
  capacityKg   Int?
  status       VehicleStatus @default(ACTIVE)
  note         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  trips        LinehaulTrip[]

  @@index([status])
  @@map("vehicles")
}

model Driver {
  id          String        @id @default(cuid())
  driverCode  String        @unique
  userId      String?
  fullName    String
  phone       String?
  licenseNo   String?
  status      DriverStatus  @default(ACTIVE)
  note        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  trips       LinehaulTrip[]

  @@index([status])
  @@index([userId])
  @@map("drivers")
}

model LinehaulTrip {
  id                    String                @id @default(cuid())
  tripCode              String                @unique
  status                TripStatus            @default(PLANNED)
  originHubCode         String
  destinationHubCode    String
  vehicleId             String?
  driverId              String?
  plannedDepartAt       DateTime?
  actualDepartAt        DateTime?
  plannedArriveAt       DateTime?
  actualArriveAt        DateTime?
  completedAt           DateTime?
  cancelledAt           DateTime?
  note                  String?
  createdBy             String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  vehicle               Vehicle?              @relation(fields: [vehicleId], references: [id])
  driver                Driver?               @relation(fields: [driverId], references: [id])
  manifests             LinehaulTripManifest[]
  seals                 LinehaulSeal[]
  incidents             LinehaulIncident[]
  handovers             LinehaulHandover[]

  @@index([status])
  @@index([originHubCode, destinationHubCode])
  @@index([vehicleId])
  @@index([driverId])
  @@map("linehaul_trips")
}

model LinehaulTripManifest {
  id           String             @id @default(cuid())
  tripId       String
  manifestId   String?
  manifestCode String
  status       TripManifestStatus @default(LOADED)
  loadedAt     DateTime           @default(now())
  unloadedAt   DateTime?
  loadedBy     String?
  unloadedBy   String?
  note         String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  trip         LinehaulTrip       @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, manifestCode])
  @@index([manifestCode])
  @@map("linehaul_trip_manifests")
}

model LinehaulSeal {
  id          String       @id @default(cuid())
  tripId      String
  sealCode    String
  direction   SealDirection
  scannedAt   DateTime     @default(now())
  scannedBy   String?
  photoUrl    String?
  note        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  trip        LinehaulTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, sealCode, direction])
  @@index([sealCode])
  @@map("linehaul_seals")
}

model LinehaulIncident {
  id           String       @id @default(cuid())
  tripId       String
  incidentType String
  severity     String?
  description  String
  photoUrls    Json?
  reportedBy   String?
  reportedAt   DateTime     @default(now())
  resolvedAt   DateTime?
  resolution   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  trip         LinehaulTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([incidentType])
  @@index([reportedAt])
  @@map("linehaul_incidents")
}

model LinehaulHandover {
  id           String       @id @default(cuid())
  tripId       String
  hubCode      String
  fromUser     String?
  toUser       String?
  note         String?
  signedAt     DateTime     @default(now())
  signatureUrl String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  trip         LinehaulTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([hubCode])
  @@index([signedAt])
  @@map("linehaul_handovers")
}
