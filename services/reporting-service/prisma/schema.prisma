generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model KpiDaily {
  id                  String   @id @default(cuid())
  metricDate          DateTime
  courierCode         String   @default("ALL")
  hubCode             String   @default("ALL")
  zoneCode            String   @default("ALL")
  shipmentsCreated    Int      @default(0)
  pickupsCompleted    Int      @default(0)
  deliveriesDelivered Int      @default(0)
  deliveriesFailed    Int      @default(0)
  ndrCreated          Int      @default(0)
  scansInbound        Int      @default(0)
  scansOutbound       Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([metricDate, courierCode, hubCode, zoneCode], name: "daily_dimension_unique")
}

model KpiMonthly {
  id                  String   @id @default(cuid())
  monthKey            String
  courierCode         String   @default("ALL")
  hubCode             String   @default("ALL")
  zoneCode            String   @default("ALL")
  shipmentsCreated    Int      @default(0)
  pickupsCompleted    Int      @default(0)
  deliveriesDelivered Int      @default(0)
  deliveriesFailed    Int      @default(0)
  ndrCreated          Int      @default(0)
  scansInbound        Int      @default(0)
  scansOutbound       Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([monthKey, courierCode, hubCode, zoneCode], name: "monthly_dimension_unique")
}

model AggregationJob {
  id          String   @id @default(cuid())
  jobType     String
  jobKey      String   @unique
  status      String
  occurredAt  DateTime?
  payload     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ShipmentStatusProjection {
  id            String   @id @default(cuid())
  shipmentCode  String   @unique
  currentStatus String
  lastEventType String
  lastEventAt   DateTime
  courierCode   String?
  hubCode       String?
  zoneCode      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([currentStatus], map: "shipment_status_current_status_idx")
  @@index([courierCode], map: "shipment_status_courier_idx")
  @@index([hubCode], map: "shipment_status_hub_idx")
  @@index([zoneCode], map: "shipment_status_zone_idx")
  @@index([updatedAt], map: "shipment_status_updated_at_idx")
}
