generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ShipmentCurrentStatus {
  CREATED
  UPDATED
  PICKUP_COMPLETED
  TASK_ASSIGNED
  MANIFEST_SEALED
  MANIFEST_RECEIVED
  SCAN_INBOUND
  SCAN_OUTBOUND
  DELIVERED
  DELIVERY_FAILED
  NDR_CREATED
  RETURN_STARTED
  RETURN_COMPLETED
  CANCELLED
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OutboxStatus {
  PENDING
  PUBLISHED
  FAILED
}

model Shipment {
  id                 String                @id @default(cuid())
  code               String                @unique
  /// shipment-service is the canonical owner of current_status.
  currentStatus      ShipmentCurrentStatus @default(CREATED)
  metadata           Json?
  cancellationReason String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  changeRequests     ChangeRequest[]

  @@map("shipments")
}

model ChangeRequest {
  id           String              @id @default(cuid())
  shipmentCode String
  requestType  String
  payload      Json
  status       ChangeRequestStatus @default(PENDING)
  requestedBy  String?
  approvedBy   String?
  approvedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  shipment     Shipment            @relation(fields: [shipmentCode], references: [code])

  @@index([shipmentCode, status])
  @@map("change_requests")
}

model OutboxEvent {
  id            String       @id @default(cuid())
  eventId       String       @unique
  eventType     String
  routingKey    String
  aggregateType String
  aggregateId   String?
  payload       Json
  status        OutboxStatus @default(PENDING)
  retryCount    Int          @default(0)
  occurredAt    DateTime
  publishedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status, occurredAt])
  @@map("outbox_events")
}
