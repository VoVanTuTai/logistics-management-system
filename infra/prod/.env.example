PUBLIC_HOST=103.179.172.53

# Public HTTPS URLs used by browsers. Vite embeds GATEWAY_PUBLIC_URL into the
# frontend bundle at build time, so keep it HTTPS when the web apps use HTTPS.
# The host Nginx config proxies API prefixes on ops.nexus-ex.site to gateway-bff,
# avoiding a separate api.* DNS record.
OPS_PUBLIC_URL=https://ops.nexus-ex.site
MERCHANT_PUBLIC_URL=https://merchant.nexus-ex.site
ADMIN_PUBLIC_URL=https://admin.nexus-ex.site
PUBLIC_TRACKING_PUBLIC_URL=https://tracking.nexus-ex.site
GATEWAY_PUBLIC_URL=https://ops.nexus-ex.site
MINIO_PUBLIC_ENDPOINT=https://minio.nexus-ex.site

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-postgres-password

RABBITMQ_DEFAULT_USER=nexus
RABBITMQ_DEFAULT_PASS=change-this-rabbitmq-password

MINIO_ROOT_USER=nexusminio
MINIO_ROOT_PASSWORD=change-this-minio-password
MINIO_BUCKET_NAME=nexus-pod-images

GATEWAY_AUTH_ENABLED=true
CORS_ORIGINS=https://ops.nexus-ex.site,https://merchant.nexus-ex.site,https://admin.nexus-ex.site,https://tracking.nexus-ex.site

ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

COMPANY_BANK_NAME=Vietcombank
COMPANY_BANK_ACCOUNT_NUMBER=1234567890
COMPANY_BANK_ACCOUNT_NAME=CONG TY TNHH NEXUS EXPRESS
COMPANY_BANK_BIN=970436
SEPAY_WEBHOOK_SECRET=
SEPAY_WEBHOOK_API_KEY=
SEPAY_WEBHOOK_TOLERANCE_SECONDS=300
SEPAY_BANK_ACCOUNT_NUMBER=1234567890
SEPAY_AMOUNT_TOLERANCE_VND=0

OPS_WEB_PORT=5173
MERCHANT_WEB_PORT=5174
ADMIN_WEB_PORT=5175
PUBLIC_TRACKING_PORT=5176
GATEWAY_PORT=3000
MINIO_API_PORT=9000

SEED_DEMO_DATA=1
