{
  "expo": {
    "name": "courier-mobile",
    "slug": "courier-mobile",
    "version": "1.0.3",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.nexuslogistics.couriermobile",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#185FA5"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Cho phép ứng dụng dùng camera để quét QR/barcode cho tác vụ giao nhận."
        }
      ],
      "expo-font",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "aae5906f-3a19-4e32-b7b5-b14d551f0c8e"
      }
    }
  }
}
